# 应用基本信息
APP_NAME=FastAPI Backend
VERSION=1.0.0
DESCRIPTION=FastAPI Backend API
DEBUG=False

# 数据库配置
# PostgreSQL 配置（生产环境推荐）
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fastapi_db

# SQLite 配置（开发环境使用）
# DATABASE_URL=sqlite:///./fastapi.db

# JWT 认证配置
# 生产环境必须修改为强随机密钥！可以使用以下命令生成：
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=1

# CORS 跨域配置
# 列出允许访问 API 的前端域名，多个域名用逗号分隔
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]
